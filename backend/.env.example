# Application Configuration
APP_NAME=Sellor API
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://sellor_user:sellor_password@localhost:5432/sellor_db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Password Hashing
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_EXTENSIONS=[".jpg",".jpeg",".png",".webp"]
UPLOAD_DIR=uploads

# Storage Configuration (local, s3, cloudinary)
STORAGE_TYPE=local

# AWS S3 (if using S3)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=sellor-uploads
# AWS_REGION=ap-southeast-1

# Cloudinary (if using Cloudinary)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (optional)
EMAIL_ENABLED=False
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@sellor.com

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
